import random
import time
lista_palabrasecreta=["SAKA", "PALMER", "RAPHINHA", "COURTOIS", "VITINHA", "PEDRI", "KANE", "YAMAL", "HAALAND", "MBAPPE"]
lista_ahorcado=["A","H","O","R","C","A","D","O"]
continuar="s"
while continuar=="s":
    lista_partida=[]
    lista_errores=[]
    lista_aciertos=[]
    errores=0
    aciertos=0
    letra=""
    palabra_escogida=random.choice(lista_palabrasecreta)
    for i in range(0, len(palabra_escogida)):
        lista_partida.append("_")
    print(*lista_partida)
    print()
    comienzo_tiempo=time.time()
    while "_" in lista_partida and errores<8:
        letra=input("Introduce una letra:").upper()
        if letra in palabra_escogida:
            aciertos=aciertos+1
            lista_aciertos.append(letra)
            for x in range(len(palabra_escogida)):
                if palabra_escogida[x]==letra:
                    lista_partida[x]=letra
        else:
            errores=errores+1
            lista_errores.append(letra)
            print("La letra introducida no está en la palabra")
            print(*lista_ahorcado[:errores])
        print(*lista_partida)
        print(f"Aciertos:", lista_aciertos)
        print(f"Errores:", lista_errores)
    if "_" not in lista_partida:
        print("¡Has ganado!")
    elif errores==8:
        print("¡Has perdido!")
    final_tiempo=time.time()
    tiempo_total=final_tiempo-comienzo_tiempo
    tiempo_minutos=int(tiempo_total//60)
    tiempo_segundos=int(tiempo_total%60)
    lista_palabrasecreta.remove(palabra_escogida)
    print(f"Número de aciertos:{aciertos}")
    print(f"Número de errores:{errores}")
    print(f"Tiempo:{tiempo_minutos} minutos y {tiempo_segundos} segundos")
    continuar=input("¿Quieres jugar otra partida? s/n:").lower()
    nueva=input("¿Quieres añadir un nuevo jugador de futbol a la lista? s/n:").lower()
    if nueva=="s":
        palabra_nueva=input("Introduce el jugador de futbol que quieres añadir a la lista:").upper()
        lista_palabrasecreta.append(palabra_nueva)
    else:
        continue
